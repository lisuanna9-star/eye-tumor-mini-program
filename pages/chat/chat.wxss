.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, #d8f3dc 0%, transparent 34%),
    linear-gradient(180deg, #f4f7f8 0%, #edf6f9 100%);
}

.hero {
  padding: 36rpx 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #0f4c5c 0%, #1f7a8c 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(15, 76, 92, 0.18);
}

.hero__badge {
  display: inline-block;
  margin-bottom: 18rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
}

.hero__title {
  font-size: 42rpx;
  font-weight: 700;
}

.hero__desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.9);
}

.hero__notice {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.12);
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.88);
}

.messages {
  height: 960rpx;
  margin-top: 24rpx;
  padding-bottom: 24rpx;
}

.suggestions {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 22rpx;
}

.suggestion {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #0f4c5c;
  font-size: 24rpx;
  box-shadow: 0 8rpx 18rpx rgba(23, 49, 59, 0.06);
}

.message {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(23, 49, 59, 0.08);
}

.message--user {
  background: #dff3e4;
}

.message__role {
  margin-bottom: 12rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #42616b;
}

.message__content {
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.sources {
  margin-top: 20rpx;
  border-top: 2rpx solid #eef3f4;
  padding-top: 20rpx;
}

.sources__title {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.source-card {
  margin-bottom: 14rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #f6fbfc;
}

.source-card__name {
  font-size: 26rpx;
  font-weight: 700;
}

.source-card__meta,
.source-card__url {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #58727a;
  word-break: break-all;
}

.source-card__snippet {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #2d505a;
}

.source-card__actions {
  margin-top: 14rpx;
}

.source-card__button {
  margin: 0;
  border-radius: 999rpx;
  background: #d7ecef;
  color: #0f4c5c;
}

.composer {
  position: sticky;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  align-items: flex-end;
  margin-top: 12rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 24rpx rgba(23, 49, 59, 0.06);
}

.composer__input {
  flex: 1;
  min-height: 84rpx;
  max-height: 220rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f3f7f7;
  font-size: 28rpx;
  box-sizing: border-box;
}

.composer__button {
  width: 160rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 22rpx;
  background: #0f4c5c;
  color: #ffffff;
  font-size: 28rpx;
}
